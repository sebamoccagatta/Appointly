{
    "extends": "../tsconfig.json",
    "compilerOptions": {
      "composite": true,
      "declaration": true,
      "declarationMap": true,
      "outDir": "dist",
      "rootDir": "src",
      "target": "ES2022",
      "module": "ESNext",
      "moduleResolution": "Bundler",
      "strict": true,
      "noImplicitOverride": true,
      "noUncheckedIndexedAccess": true,
      "esModuleInterop": true,
      "skipLibCheck": true
    },
    "include": ["src", "**/*.test.ts"],
    "exclude": ["dist"]
  }
  